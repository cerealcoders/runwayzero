# Required for the agent to run
ANTHROPIC_API_KEY=sk-ant-...
GENSPARK_API_KEY=gs-...

# Targets — populated after Phase A8
RUNWAYZERO_TEST_EC2_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
RUNWAYZERO_TEST_EC2_HOST=<test-ec2-private-ip>:8080
RUNWAYZERO_TEST_EC2_ROLE_NAME=<exact role name returned by IMDS, see A8 step 4>

# Path to the demo-app repo on this workstation (sandbox tests need PYTHONPATH to app.py)
RUNWAYZERO_APP_MODULE_DIR=/home/eugene/KrisCloud/Repos/demo-app/platform/ansible/roles/runwayzero-demo/files

# Optional: override defaults
AWS_REGION=ap-southeast-1
